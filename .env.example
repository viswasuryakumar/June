# Copy to .env and fill in real values. .env is git-ignored - never commit it.
# Loaded by src/config/secrets.py:load_secrets(); required vars are validated
# fail-fast at startup and their values are redacted from all log output.

JOBRIGHT_EMAIL=
JOBRIGHT_PASSWORD=

# Optional: set to "true" if this account signs in via Google SSO (see
# Epic 2 T2.2.2 for the human-assisted first-login flow this implies).
JOBRIGHT_SSO=false

# Optional notifier tokens (Epic 7/8).
NOTIFIER_SLACK_WEBHOOK_URL=
NOTIFIER_TELEGRAM_TOKEN=
