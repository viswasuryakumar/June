# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Secrets - never commit
.env
config/secrets.yaml

# Runtime-writable personal application data (learned answers, real PII)
config/application_data.yaml

# Runtime artifacts (screenshots, HTML dumps, logs per run)
runs/*
!runs/.gitkeep

# Git worktrees/checkpoints created by the development supervisor when configured in-repo.
.devloop-worktrees/

# Browser profile (persistent Chromium profile dir per spec §2)
.jobright-autopilot/

# JSON schema exports (generated; regenerate via src/contracts/schema_export.py)
contracts/schemas/

# OS/editor cruft
.DS_Store
